# LICENSE402 configuration. Copy to .env.local and fill in.
# NEVER commit .env.local — it holds private keys and API credentials.

PORT=8799
PUBLIC_ORIGIN=https://license402.axiqo.xyz

# off = wallet-free demo (simulated settlement, everything labeled DEV)
# live = real OKX x402 settlement on X Layer (requires OKX_* credentials + a funded wallet)
PAYMENT_MODE=off

# X Layer (OKB chain, chainId 196)
X402_NETWORK=eip155:196
X402_PRICE=$0.10
X402_ASSET=0x779Ded0c9e1022225f8E0630b35a9b54bE713736
XLAYER_RPC=https://rpc.xlayer.tech

# Signing keys (0x + 64 hex). Generate fresh; do not reuse across environments.
SERVICE_WALLET_PRIVATE_KEY=
ISSUER_PRIVATE_KEY=
DEMO_CREATOR_PRIVATE_KEY=
DEMO_BUYER_PRIVATE_KEY=
PAY_TO_ADDRESS=

# OKX Onchain OS Dev Portal (only needed when PAYMENT_MODE=live)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
